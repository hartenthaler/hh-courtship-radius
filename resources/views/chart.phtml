<?php if ($analysis['excluded'] !== []) : ?>
    <?php View::push('javascript') ?>
    <script>
    document.querySelectorAll('#<?= e($qualityTableId) ?> [data-courtship-sort]').forEach(button => {
      button.addEventListener('click', () => {
        const table = document.getElementById(<?= json_encode($qualityTableId, JSON_THROW_ON_ERROR) ?>);
        const tbody = table.querySelector('tbody');
        const column = Number(button.dataset.courtshipSort);
        const ascending = button.dataset.sortDirection !== 'asc';
        const rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort((left, right) => {
          const leftValue = left.children[column].dataset.sort || left.children[column].textContent.trim();
          const rightValue = right.children[column].dataset.sort || right.children[column].textContent.trim();
          const result = leftValue.localeCompare(rightValue, document.documentElement.lang || undefined, {numeric: true, sensitivity: 'base'});
          return ascending ? result : -result;
        });

        table.querySelectorAll('[data-courtship-sort]').forEach(item => delete item.dataset.sortDirection);
        button.dataset.sortDirection = ascending ? 'asc' : 'desc';
        rows.forEach(row => tbody.appendChild(row));
      });
    });
    </script>
    <?php View::endpush() ?>
<?php endif ?>
