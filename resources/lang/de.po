msgstr "Keiner der Partner liegt als Person im Sammelbehälter vor"

#: .\resources\views\chart.phtml:37
msgid "No usable marriage date"
msgstr "Kein verwendbares Heiratsdatum"

#: .\resources\views\chart.phtml:38
