msgid "Courtship radius over time"
msgstr "Partnerzoekradius in de tijd"

#: .\resources\views\chart.phtml:85
msgid ""
"The courtship radius is the distance at or below which 90 percent of all "
"evaluated distances lie."
msgstr ""
"De partnerzoekradius is de afstand waarbinnen 90 procent van alle "
"geëvalueerde afstanden ligt."

#: .\resources\views\chart.phtml:92
msgid "Courtship radius (P90)"
msgstr "Partnerzoekradius (P90)"

#: .\resources\views\chart.phtml:104
