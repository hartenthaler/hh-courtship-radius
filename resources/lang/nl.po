msgstr "Geboorteplaats × huwelijksplaats"

#: .\resources\views\chart.phtml:121
msgid "Each cell contains the number of evaluated persons."
msgstr "Elke cel bevat het aantal geëvalueerde personen."

#: .\resources\views\chart.phtml:131
msgid "Movement map"
msgstr "Verplaatsingskaart"

#: .\resources\views\chart.phtml:136
msgid "Blood-related spouses"
msgstr "Bloedverwante echtgenoten"

#: .\resources\views\chart.phtml:138
